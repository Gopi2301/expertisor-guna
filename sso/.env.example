# This file contains all the secrets and configuration for the backend application.
# It MUST be located at /home/yppgpgkj/backend/.env

# --- Core Application URLs ---
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:8000/api
PUBLIC_URL=http://localhost:5999

# --- Security ---
APP_JWT_SECRET=your_jwt_secret_here

# --- VirtuaGrid (For OTP and User Management) ---
VIRTUAGRID_BASE_URL=https://virtuagrid.com
VIRTUAGRID_APP_ID=your_virtuagrid_app_id

# --- Google OAuth 2.0 ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# --- Graphy (Course Platform SSO) ---
GRAPHY_API_TOKEN=your_graphy_api_token
Graphy_MID=your_graphy_mid
